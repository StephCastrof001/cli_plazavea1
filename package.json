{
  "name": "plazavea-cli",
  "version": "3.1.0",
  "description": "Servidor MCP para retail VTEX — Plaza Vea. CLI + 11 tools para Claude Code, Cursor y cualquier cliente MCP.",
  "type": "module",
  "license": "MIT",
  "author": "Stephanie Castro",
  "repository": {
    "type": "git",
    "url": "https://github.com/StephCastrof001/cli_plazavea1.git"
  },
  "keywords": [
    "mcp",
    "vtex",
    "retail",
    "plaza-vea",
    "claude-code",
    "cursor",
    "cli",
    "peru",
    "supermercado"
  ],
  "files": [
    "index.ts",
    "server.ts",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "plaza": "./index.ts"
  },
  "scripts": {
    "plaza": "bun run index.ts",
    "login": "node node_modules/tsx/dist/cli.mjs src/commands/login.ts",
    "mcp": "bun run src/mcp/server.ts",
    "server": "bun run server.ts",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "chalk": "^5.3.0",
    "hono": "^4.12.0",
    "picocolors": "^1.1.1",
    "playwright": "1.59.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "tsx": "^4.22.3"
  }
}
